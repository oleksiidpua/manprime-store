generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  name         String?
  surname      String?
  email        String    @unique
  phone        String?
  passwordHash String?
  role         Role      @default(CUSTOMER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  addresses    Address[]
  orders       Order[]
  accounts     Account[]
  sessions     Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  city       String
  street     String
  house      String
  apartment  String?
  postalCode String?
  isDefault  Boolean @default(false)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  nameUk      String
  nameRu      String
  nameEn      String
  descUk      String
  descRu      String
  descEn      String
  compUk      String
  compRu      String
  compEn      String
  price       Int
  imageUrl    String?
  stock       Int         @default(100)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  guestName     String?
  guestEmail    String?
  guestPhone    String?
  status        OrderStatus @default(PENDING)
  totalPrice    Int
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(UNPAID)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User?       @relation(fields: [userId], references: [id])
  items         OrderItem[]
  shipment      Shipment?
  deliveryCity  String?
  deliveryStreet String?
  deliveryHouse String?
  deliveryApt   String?
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Shipment {
  id        String   @id @default(cuid())
  orderId   String   @unique
  carrier   Carrier
  ttn       String?
  status    String   @default("created")
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  LIQPAY
  MONOBANK
  PORTMONE
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum Carrier {
  NOVAPOSHTA
  UKRPOSHTA
}
